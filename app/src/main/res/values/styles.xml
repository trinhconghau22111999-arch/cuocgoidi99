<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.SimpleCall" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/primary</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
        <item name="android:windowSoftInputMode">stateAlwaysVisible</item>
    </style>

    <style name="Theme.SimpleCall.InCall" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@color/incall_bg</item>
        <item name="android:statusBarColor">@color/incall_bg</item>
        <item name="android:navigationBarColor">@color/incall_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>

    <!-- KeyBtn: to, độ đậm chữ giảm còn ~70% so với trước (bỏ textStyle=bold và đổi
         fontFamily từ sans-serif-medium -> sans-serif thường, chữ mảnh hơn rõ rệt) -->
    <style name="KeyBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">68dp</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:layout_gravity">fill_horizontal</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bg_key</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:textSize">30sp</item>
        <item name="android:lines">1</item>
    </style>

    <!-- Chữ "Gần đây" / "Danh bạ" ở bottom nav - đậm hơn (dày ~1.3 lần so với chữ mỏng mặc định) -->
    <style name="BottomNavLabel" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Màu "viên thuốc" active-indicator của tab đang chọn ở bottom nav. Trước đây bị gán nhầm
         qua app:itemActiveIndicatorColor trực tiếp trên BottomNavigationView - attribute đó
         KHÔNG tồn tại trong NavigationBarView (chỉ có itemActiveIndicatorStyle trỏ tới 1 style,
         màu thật sự nằm trong style đó qua android:color) nên aapt2 báo lỗi linking, build fail. -->
    <style name="BottomNavActiveIndicator">
        <item name="android:color">@color/accent_blue</item>
    </style>

</resources>
