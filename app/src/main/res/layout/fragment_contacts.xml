<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- Icon cài đặt (lục giác) góc trên bên phải -->
    <FrameLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:paddingTop="16dp" android:paddingEnd="20dp">
        <ImageButton
            android:id="@+id/btnContactsSettings"
            android:layout_width="40dp" android:layout_height="40dp"
            android:layout_gravity="end"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_hexagon_settings"
            android:contentDescription="@string/settings" />
    </FrameLayout>

    <!-- Tiêu đề "Danh bạ" + số lượng liên hệ -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp" android:paddingEnd="20dp"
        android:paddingTop="4dp">
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/contacts_title"
            android:textSize="34sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium" />
        <TextView
            android:id="@+id/tvContactsCount"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Search bar pill - Google style -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_search"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            android:layout_marginEnd="10dp"
            android:alpha="0.6" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:hint="Tìm kiếm"
            android:textColorHint="@color/text_hint"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif"
            android:imeOptions="actionSearch"
            android:inputType="text" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingEnd="22dp"
            android:clipToPadding="false" />

        <!-- Thanh chỉ mục chữ cái A-Z bên phải, bấm vào để nhảy nhanh tới liên hệ -->
        <LinearLayout
            android:id="@+id/llAlphabetIndex"
            android:layout_width="22dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|end"
            android:orientation="vertical"
            android:gravity="center_horizontal" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAddContact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/ic_add"
            app:tint="@color/fab_icon"
            app:backgroundTint="@color/fab_bg"
            app:fabSize="normal"
            android:contentDescription="@string/add_contact" />
    </FrameLayout>
</LinearLayout>
