<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/incall_bg">

    <!-- Avatar -->
    <FrameLayout android:id="@+id/avatarWrap"
        android:layout_width="88dp" android:layout_height="88dp"
        android:layout_marginTop="64dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <View android:id="@+id/avatarView"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:background="@drawable/bg_avatar" />
        <TextView android:id="@+id/tvAvatarLetter"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:gravity="center" android:textSize="36sp"
            android:textColor="@color/avatar_text"
            android:fontFamily="sans-serif-medium" android:text="?" />
        <!-- Ảnh danh bạ thật (đè lên avatar chữ nếu có) -->
        <ImageView android:id="@+id/ivContactPhoto"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone" />
    </FrameLayout>

    <TextView android:id="@+id/tvCallerName"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="40dp" android:layout_marginEnd="40dp"
        android:gravity="center"
        android:textColor="@color/text_on_dark" android:textSize="28sp"
        android:fontFamily="sans-serif" android:singleLine="true"
        app:layout_constraintTop_toBottomOf="@id/avatarWrap"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Số điện thoại (hiện dưới tên nếu có tên) -->
    <TextView android:id="@+id/tvCallerNumber"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:textColor="#9AA0A6" android:textSize="14sp"
        android:fontFamily="sans-serif"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvCallerName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Dòng SIM + quốc gia (vd "[2] Việt Nam") - chỉ hiện khi biết SIM đang dùng để gọi -->
    <LinearLayout android:id="@+id/llSimLine"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginTop="6dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvCallerNumber"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView android:id="@+id/tvSimBadge"
            android:layout_width="18dp" android:layout_height="18dp"
            android:gravity="center" android:text="2"
            android:textSize="11sp" android:textColor="#9AA0A6"
            android:background="@drawable/bg_sim_badge" />
        <TextView android:id="@+id/tvCarrier"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textColor="#9AA0A6" android:textSize="14sp"
            android:fontFamily="sans-serif" android:text="Việt Nam" />
    </LinearLayout>

    <!-- Badge HD + trạng thái/giờ gọi, gộp chung 1 hàng để tránh constraint vòng lặp -->
    <LinearLayout android:id="@+id/llStatusLine"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/llSimLine"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView android:id="@+id/tvHdBadge"
            android:layout_width="wrap_content" android:layout_height="18dp"
            android:paddingStart="4dp" android:paddingEnd="4dp"
            android:gravity="center" android:text="HD"
            android:textSize="10sp" android:textColor="#9AA0A6"
            android:background="@drawable/bg_sim_badge"
            android:layout_marginEnd="6dp"
            android:visibility="gone" />

        <TextView android:id="@+id/tvCallStatus"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#9AA0A6" android:textSize="14sp"
            android:fontFamily="sans-serif" />
    </LinearLayout>

    <!-- INCOMING controls -->
    <LinearLayout android:id="@+id/incomingControls"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center"
        android:layout_marginStart="24dp" android:layout_marginEnd="24dp"
        android:layout_marginBottom="64dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageButton android:id="@+id/btnDecline"
                android:layout_width="72dp" android:layout_height="72dp"
                android:background="@drawable/bg_decline_circle"
                android:src="@drawable/ic_call_end"
                android:contentDescription="@string/decline"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Từ chối" android:textColor="#9AA0A6" android:textSize="13sp"
                android:layout_marginTop="10dp" android:fontFamily="sans-serif"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageButton android:id="@+id/btnAnswer"
                android:layout_width="72dp" android:layout_height="72dp"
                android:background="@drawable/bg_call_circle"
                android:src="@drawable/ic_call"
                android:contentDescription="@string/answer"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Trả lời" android:textColor="#9AA0A6" android:textSize="13sp"
                android:layout_marginTop="10dp" android:fontFamily="sans-serif"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ACTIVE controls -->
    <LinearLayout android:id="@+id/activeControls"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:orientation="vertical" android:visibility="gone"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Row 1: Ghi âm | Tắt mic | Giữ -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center"
            android:layout_marginBottom="20dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageButton android:id="@+id/btnRecord"
                    android:layout_width="56dp" android:layout_height="56dp"
                    android:background="@drawable/bg_action_circle"
                    android:src="@drawable/ic_mic"
                    android:contentDescription="@string/start_recording"/>
                <TextView android:id="@+id/tvRecordLabel"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/start_recording" android:textColor="#9AA0A6" android:textSize="12sp"
                    android:layout_marginTop="6dp" android:fontFamily="sans-serif"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageButton android:id="@+id/btnMute"
                    android:layout_width="56dp" android:layout_height="56dp"
                    android:background="@drawable/bg_action_circle"
                    android:src="@drawable/ic_mic"
                    android:contentDescription="@string/mute"/>
                <TextView android:id="@+id/tvMuteLabel"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Tắt mic" android:textColor="#9AA0A6" android:textSize="12sp"
                    android:layout_marginTop="6dp" android:fontFamily="sans-serif"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageButton android:id="@+id/btnHold"
                    android:layout_width="56dp" android:layout_height="56dp"
                    android:background="@drawable/bg_action_circle"
                    android:src="@drawable/ic_call_hold"
                    android:contentDescription="@string/hold_call"/>
                <TextView android:id="@+id/tvHoldLabel"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/hold_call" android:textColor="#9AA0A6" android:textSize="12sp"
                    android:layout_marginTop="6dp" android:fontFamily="sans-serif"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2: Gọi rõ ràng | Thêm cuộc gọi | Thêm -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center"
            android:layout_marginBottom="24dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageButton android:id="@+id/btnClarity"
                    android:layout_width="56dp" android:layout_height="56dp"
                    android:background="@drawable/bg_action_circle"
                    android:src="@drawable/ic_call_clarity"
                    android:contentDescription="@string/call_clarity"/>
                <TextView android:id="@+id/tvClarityLabel"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/call_clarity" android:textColor="#9AA0A6" android:textSize="12sp"
                    android:layout_marginTop="6dp" android:fontFamily="sans-serif"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageButton android:id="@+id/btnAddCall"
                    android:layout_width="56dp" android:layout_height="56dp"
                    android:background="@drawable/bg_action_circle"
                    android:src="@drawable/ic_add"
                    android:contentDescription="@string/add_call"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/add_call" android:textColor="#9AA0A6" android:textSize="12sp"
                    android:layout_marginTop="6dp" android:fontFamily="sans-serif"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageButton android:id="@+id/btnMore"
                    android:layout_width="56dp" android:layout_height="56dp"
                    android:background="@drawable/bg_action_circle"
                    android:src="@drawable/ic_expand_more"
                    android:contentDescription="@string/more_options"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/more_options" android:textColor="#9AA0A6" android:textSize="12sp"
                    android:layout_marginTop="6dp" android:fontFamily="sans-serif"/>
            </LinearLayout>
        </LinearLayout>

        <!-- DTMF panel (ẩn mặc định) -->
        <GridLayout android:id="@+id/dtmfPanel"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:columnCount="3" android:rowCount="4"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:text="1" android:tag="1" android:textColor="@color/text_on_dark"/>
            <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:text="2" android:tag="2" android:textColor="@color/text_on_dark"/>
            <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:text="3" android:tag="3" android:textColor="@color/text_on_dark"/>
            <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:text="4" android:tag="4" android:textColor="@color/text_on_dark"/>
            <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:text="5" android:tag="5" android:textColor="@color/text_on_dark"/>
            <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:text="6" android:tag="6" android:textColor="@color/text_on_dark"/>
            <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:text="7" android:tag="7" android:textColor="@color/text_on_dark"/>
            <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:text="8" android:tag="8" android:textColor="@color/text_on_dark"/>
            <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:text="9" android:tag="9" android:textColor="@color/text_on_dark"/>
            <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:text="*" android:tag="*" android:textColor="@color/text_on_dark"/>
            <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:text="0" android:tag="0" android:textColor="@color/text_on_dark"/>
            <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:text="#" android:tag="#" android:textColor="@color/text_on_dark"/>
        </GridLayout>

        <!-- Bottom row: Loa ngoài | Kết thúc | Bàn phím -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageButton android:id="@+id/btnSpeaker"
                    android:layout_width="56dp" android:layout_height="56dp"
                    android:background="@drawable/bg_action_circle"
                    android:src="@drawable/ic_volume_up"
                    android:contentDescription="@string/speaker"/>
                <TextView android:id="@+id/tvSpeakerLabel"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Loa ngoài" android:textColor="#9AA0A6" android:textSize="12sp"
                    android:layout_marginTop="6dp" android:fontFamily="sans-serif"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageButton android:id="@+id/btnEndCall"
                    android:layout_width="72dp" android:layout_height="72dp"
                    android:background="@drawable/bg_decline_circle"
                    android:src="@drawable/ic_call_end"
                    android:contentDescription="@string/end_call"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Kết thúc" android:textColor="#9AA0A6" android:textSize="13sp"
                    android:layout_marginTop="10dp" android:fontFamily="sans-serif"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageButton android:id="@+id/btnDtmf"
                    android:layout_width="56dp" android:layout_height="56dp"
                    android:background="@drawable/bg_action_circle"
                    android:src="@drawable/ic_dialpad"
                    android:contentDescription="Bàn phím"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Bàn phím" android:textColor="#9AA0A6" android:textSize="12sp"
                    android:layout_marginTop="6dp" android:fontFamily="sans-serif"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
