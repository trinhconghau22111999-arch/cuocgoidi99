<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- Mặc định: danh sách "Gần đây" (Nhật ký cuộc gọi thật trên máy).
         Khi người dùng gõ số (>=2 chữ số) thì ẩn cái này, hiện rvSuggestions thay thế.
         layout_weight=1 để chiếm hết khoảng trống còn lại; khi bàn phím bị ẩn (GONE)
         danh sách này sẽ giãn ra chiếm luôn phần đó -> xem trọn danh sách. -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRecents"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/bg" />

    <!-- Gợi ý liên hệ khớp với số đang gõ (ẩn mặc định, thay thế rvRecents khi tìm kiếm) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSuggestions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:background="@color/bg" />

    <!-- Number display: nằm giáp và ngay phía trên bàn phím -->
    <FrameLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:minHeight="72dp"
        android:paddingStart="32dp" android:paddingEnd="4dp"
        android:paddingTop="8dp" android:paddingBottom="4dp">

        <EditText
            android:id="@+id/etNumber"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="52dp"
            android:background="@null"
            android:gravity="center"
            android:textSize="36sp" android:textColor="@color/text_primary"
            android:letterSpacing="0.03"
            android:fontFamily="sans-serif-light"
            android:singleLine="true"
            android:cursorVisible="true"
            android:focusable="true" android:focusableInTouchMode="true" />

        <ImageButton
            android:id="@+id/btnBackspace"
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_gravity="center_vertical|end"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_backspace"
            android:contentDescription="Xóa"
            android:visibility="invisible" />
    </FrameLayout>

    <!-- Keypad: dùng AppCompatButton (không phải <Button>) để tránh Material Components
         tự động tô nền bằng colorPrimary (đó là lý do phím bị xanh trước đây).
         Kích thước 76dp (xem style KeyBtn), không kéo giãn lấp đầy màn hình. -->
    <GridLayout
        android:id="@+id/keypad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:columnCount="3" android:rowCount="4">

        <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:id="@+id/key1"  android:text="1"  android:tag="1" />
        <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:id="@+id/key2"  android:text="2"  android:tag="2" />
        <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:id="@+id/key3"  android:text="3"  android:tag="3" />
        <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:id="@+id/key4"  android:text="4"  android:tag="4" />
        <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:id="@+id/key5"  android:text="5"  android:tag="5" />
        <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:id="@+id/key6"  android:text="6"  android:tag="6" />
        <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:id="@+id/key7"  android:text="7"  android:tag="7" />
        <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:id="@+id/key8"  android:text="8"  android:tag="8" />
        <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:id="@+id/key9"  android:text="9"  android:tag="9" />
        <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:id="@+id/keyStar" android:text="✱" android:tag="*" android:textSize="24sp"/>
        <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:id="@+id/key0"  android:text="0"  android:tag="0" />
        <androidx.appcompat.widget.AppCompatButton style="@style/KeyBtn" android:id="@+id/keyHash" android:text="#" android:tag="#" android:textSize="24sp"/>
    </GridLayout>

    <!-- Hàng nút dưới cùng: trái = gọi video, giữa = gọi, phải = bàn phím (cân đối 3 cột đều nhau) -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="96dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="8dp" android:paddingBottom="8dp">

        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <ImageButton android:id="@+id/btnVideoCall"
                android:layout_width="52dp" android:layout_height="52dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_key"
                android:src="@drawable/ic_video_call"
                android:tint="@color/text_secondary"
                android:contentDescription="@string/video_call" />
        </FrameLayout>

        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <ImageButton android:id="@+id/btnCall"
                android:layout_width="64dp" android:layout_height="64dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_call_circle"
                android:src="@drawable/ic_call"
                android:contentDescription="@string/call" />
        </FrameLayout>

        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <ImageButton android:id="@+id/btnKeypadToggle"
                android:layout_width="52dp" android:layout_height="52dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_key"
                android:src="@drawable/ic_dialpad"
                android:tint="@color/text_secondary"
                android:contentDescription="@string/open_dialpad" />
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
