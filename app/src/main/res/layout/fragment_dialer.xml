<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- Vùng nội dung linh hoạt: gợi ý liên hệ / danh sách gần đây / hành động khi không khớp.
         Nằm TRÊN CÙNG, phía trên ô nhập số + bàn phím (không phải ngược lại). -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRecents"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSuggestions"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/llNoMatchActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/rowCreateContact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_settings_row"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_add"
                    app:tint="@color/white"
                    tools:ignore="MissingClass" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="24dp"
                    android:text="@string/create_new_contact"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowAddToExisting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_settings_row"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_person"
                    app:tint="@color/white"
                    tools:ignore="MissingClass" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="24dp"
                    android:text="@string/add_to_existing_contact"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowSendSms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_settings_row"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_dialog_email"
                    app:tint="@color/white"
                    tools:ignore="MissingClass" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="24dp"
                    android:text="@string/send_sms"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowVideoMeet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_settings_row"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_video_call"
                    app:tint="@color/white"
                    tools:ignore="MissingClass" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="24dp"
                    android:text="@string/video_call_meet"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- Ô nhập số điện thoại + nút xóa: nằm NGAY TRÊN bàn phím số (không phải trên cùng màn hình).
         showSoftInputOnFocus=false + inputType=none để tuyệt đối không bao giờ bật bàn phím
         hệ thống của máy lên - chỉ nhập được qua bàn phím số riêng của app bên dưới. -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="12dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <EditText
            android:id="@+id/etNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:paddingEnd="48dp"
            android:background="@null"
            android:inputType="none"
            android:showSoftInputOnFocus="false"
            android:gravity="center"
            android:textSize="32sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-light"
            android:cursorVisible="true"
            android:maxLines="1" />

        <ImageButton
            android:id="@+id/btnBackspace"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical|end"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_backspace"
            android:contentDescription="@string/cancel"
            android:visibility="invisible" />
    </FrameLayout>

    <!-- Viền trên của bàn phím, hiển thị rõ để tách khỏi ô nhập số phía trên -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:background="@color/divider" />

    <!-- Bàn phím số: dàn đều 3 cột từ mép trái sang mép phải. Cho phép nhập cả * và #. -->
    <GridLayout
        android:id="@+id/keypad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:columnCount="3"
        android:rowCount="4"
        android:useDefaultMargins="false">

        <Button android:tag="1" style="@style/KeyBtn" android:text="1" android:layout_columnWeight="1" />
        <Button android:tag="2" style="@style/KeyBtn" android:text="2" android:layout_columnWeight="1" />
        <Button android:tag="3" style="@style/KeyBtn" android:text="3" android:layout_columnWeight="1" />
        <Button android:tag="4" style="@style/KeyBtn" android:text="4" android:layout_columnWeight="1" />
        <Button android:tag="5" style="@style/KeyBtn" android:text="5" android:layout_columnWeight="1" />
        <Button android:tag="6" style="@style/KeyBtn" android:text="6" android:layout_columnWeight="1" />
        <Button android:tag="7" style="@style/KeyBtn" android:text="7" android:layout_columnWeight="1" />
        <Button android:tag="8" style="@style/KeyBtn" android:text="8" android:layout_columnWeight="1" />
        <Button android:tag="9" style="@style/KeyBtn" android:text="9" android:layout_columnWeight="1" />
        <Button android:tag="*" style="@style/KeyBtn" android:text="*" android:layout_columnWeight="1" />
        <Button android:tag="0" style="@style/KeyBtn" android:text="0" android:layout_columnWeight="1" />
        <Button android:tag="#" style="@style/KeyBtn" android:text="#" android:layout_columnWeight="1" />
    </GridLayout>

    <!-- Hàng điều khiển dưới cùng: video (trái) - nút gọi 1/2 SIM (giữa) - nút bật/tắt bàn phím (phải) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="16dp"
        android:paddingBottom="20dp"
        android:paddingStart="28dp"
        android:paddingEnd="28dp">

        <FrameLayout
            android:id="@+id/btnVideoCall"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center_vertical|start"
            android:background="@drawable/bg_video_call_btn"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/video_call">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_video_call"
                app:tint="@color/text_primary"
                tools:ignore="MissingClass" />

            <!-- Chấm trắng nhỏ góc trên-trái, giống icon quay video trên máy thật -->
            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_gravity="top|start"
                android:layout_marginTop="6dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_white_dot" />
        </FrameLayout>

        <ImageButton
            android:id="@+id/btnCall"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_call_circle"
            android:src="@drawable/ic_call"
            android:contentDescription="@string/call"
            android:visibility="visible" />

        <!-- Nút gọi 2 SIM: 1 viên thuốc liền mạch, 2 nửa liền kề nhau, không viền/đường kẻ ở giữa -->
        <LinearLayout
            android:id="@+id/llCallDual"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <Button
                android:id="@+id/btnCallSim1"
                android:layout_width="76dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_call_pill_left"
                android:text="1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-medium"
                android:stateListAnimator="@null"
                android:drawableStart="@drawable/ic_call"
                android:drawablePadding="8dp"
                android:paddingStart="14dp"
                android:gravity="center" />

            <Button
                android:id="@+id/btnCallSim2"
                android:layout_width="76dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_call_pill_right"
                android:text="2"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-medium"
                android:stateListAnimator="@null"
                android:drawableStart="@drawable/ic_call"
                android:drawablePadding="8dp"
                android:paddingStart="14dp"
                android:gravity="center" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnKeypadToggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical|end"
            android:background="@drawable/bg_key"
            android:src="@drawable/ic_dialpad"
            android:contentDescription="@string/open_dialpad" />
    </FrameLayout>

</LinearLayout>
