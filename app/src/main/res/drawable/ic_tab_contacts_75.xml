<?xml version="1.0" encoding="utf-8"?>
<!-- Bề ngang = 2x kích thước hiện tại (150% so với gốc), chiều cao = 3x kích thước hiện tại
     (225% so với gốc). Dùng inset ÂM để phóng to vượt khung gốc (InsetDrawable hỗ trợ giá
     trị âm để vẽ to hơn view bounds). Vì phóng to nhiều nên icon có thể tràn/đè lên chữ nhãn
     phía dưới trên thanh điều hướng - build thử xem có ổn không, không thì báo lại để chỉnh. -->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/ic_tab_contacts"
    android:insetLeft="-25%"
    android:insetTop="-62.5%"
    android:insetRight="-25%"
    android:insetBottom="-62.5%" />
